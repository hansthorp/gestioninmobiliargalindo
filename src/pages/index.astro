---
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import propiedades from '../data/propiedades.json';

// Estadísticas simplificadas
const disponibles = propiedades.filter(p => p.estatus.toLowerCase().trim() === 'disponible').length;
---

<BaseLayout title="Gestión Inmobiliaria Galindo | Catálogo">
  
  <header class="mb-12 text-center pt-8">
    <div class="mb-10">
      <img 
        src="/images/logo.jpeg" 
        alt="Galindo Gestión Inmobiliaria" 
        class="h-20 md:h-28 mx-auto object-contain transition-transform hover:scale-105 duration-300"
      />
    </div>

    <div class="flex items-center justify-center gap-4 text-slate-400 mb-6">
      <div class="h-[1px] w-8 bg-slate-200"></div>
      <p class="text-[11px] font-black uppercase tracking-[0.3em] italic">
        Contamos con <span class="text-galindo text-sm">{disponibles}</span> inmuebles disponibles para ti
      </p>
      <div class="h-[1px] w-8 bg-slate-200"></div>
    </div>

    <p class="text-[10px] text-slate-300 font-medium italic uppercase tracking-widest">
      "Calidad, honradez y profesionalismo"
    </p>
  </header>

  <div class="mb-14 flex flex-wrap justify-center gap-2 md:gap-3" id="filters-container">
    <button class="filter-btn active" data-filter="todos">Ver Todo</button>
    <button class="filter-btn" data-filter="venta">Venta</button>
    <button class="filter-btn" data-filter="renta">Renta</button>
    <button class="filter-btn" data-filter="vendido">Vendidos</button>
    <button class="filter-btn" data-filter="rentado">Rentados</button>
  </div>

  <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-3 min-h-[400px]" id="properties-grid">
    {propiedades.map((prop) => (
      <div 
        class="property-wrapper transition-all duration-500 ease-in-out" 
        data-category={prop.operacion.toLowerCase().trim()} 
        data-status={prop.estatus.toLowerCase().trim()}
      >
        <PropertyCard property={prop} />
      </div>
    ))}
  </div>
</BaseLayout>

<style is:global>
  .hidden-card { 
    opacity: 0;
    transform: scale(0.95);
    display: none !important;
  }

  /* Filtros más discretos para que no compitan con el logo */
  .filter-btn {
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
    background-color: white;
    padding: 0.6rem 1.2rem;
    font-weight: 800;
    color: #94a3b8;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  
  .filter-btn:hover:not(.active) {
    border-color: #D0162B; /* Rojo Galindo */
    color: #D0162B;
  }
  
  .filter-btn.active {
    border-color: #0f172a; /* Slate 900 */
    background-color: #0f172a;
    color: white;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
  }
</style>

<script>
  function setupFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const wrappers = document.querySelectorAll('.property-wrapper');
    
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter')?.toLowerCase().trim();
        
        wrappers.forEach(wrapper => {
          const status = wrapper.getAttribute('data-status')?.toLowerCase().trim();
          const category = wrapper.getAttribute('data-category')?.toLowerCase().trim();
          let shouldShow = false;

          if (filter === 'todos') {
            shouldShow = (status === 'disponible');
          } else if (filter === 'vendido' || filter === 'rentado') {
            shouldShow = (status === filter);
          } else {
            shouldShow = (category === filter && status === 'disponible');
          }

          if (shouldShow) {
            (wrapper as HTMLElement).style.display = 'block';
            setTimeout(() => wrapper.classList.remove('hidden-card'), 10);
          } else {
            wrapper.classList.add('hidden-card');
            (wrapper as HTMLElement).style.display = 'none';
          }
        });
      });
    });

    // Forzar el filtro inicial
    const initialBtn = document.querySelector('.filter-btn.active') as HTMLElement;
    if (initialBtn) initialBtn.click();
  }

  window.addEventListener('load', setupFilters);
  document.addEventListener('astro:after-swap', setupFilters);
</script>