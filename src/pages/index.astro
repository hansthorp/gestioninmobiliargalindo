---
import BaseLayout from '../layouts/BaseLayout.astro'; // UN SOLO PUNTO-PUNTO
import PropertyCard from '../components/PropertyCard.astro';
import propiedades from '../data/propiedades.json';

const total = propiedades.length;
const disponibles = propiedades.filter(p => p.estatus === 'disponible').length;
const cerrados = propiedades.filter(p => p.estatus === 'vendido' || p.estatus === 'rentado').length;
---

<BaseLayout title="Catálogo Inmobiliario | Fernando Pérez">
  <header class="mb-12 text-center">
    <h1 class="text-5xl font-black tracking-tight text-slate-900 italic">Tu Próximo Hogar</h1>
    <p class="mt-4 text-lg text-slate-500">Gestión profesional de inmuebles en Xalapa y Veracruz</p>
    
    <div class="mt-6 text-slate-400 font-bold uppercase text-[10px] tracking-[0.2em]">
       {disponibles} Propiedades Disponibles | {cerrados} Casos de Éxito
    </div>
  </header>

  <div class="mb-12 flex flex-wrap justify-center gap-3" id="filters-container">
    <button class="filter-btn active" data-filter="todos">🏠 Ver Todo</button>
    <button class="filter-btn" data-filter="venta">💰 Venta</button>
    <button class="filter-btn" data-filter="renta">🔑 Renta</button>
    <button class="filter-btn" data-filter="vendido">✅ Vendidos</button>
    <button class="filter-btn" data-filter="rentado">🤝 Rentados</button>
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3" id="properties-grid">
    {propiedades.map((prop) => (
      <div class="property-wrapper" data-category={prop.operacion} data-status={prop.estatus}>
        <PropertyCard property={prop} />
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .filter-btn {
    border-radius: 0.75rem;
    border-width: 2px;
    padding: 0.625rem 1.5rem;
    font-weight: 900;
    transition: all 0.3s;
    background-color: white;
    border-color: #e2e8f0;
    color: #475569;
  }
  .filter-btn:hover {
    border-color: #10b981;
    color: #059669;
  }
  .filter-btn.active {
    border-color: #0f172a;
    background-color: #0f172a;
    color: white;
  }
  .hidden-card { display: none; }
</style>

<script>
  function setupFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const wrappers = document.querySelectorAll('.property-wrapper');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter');
        wrappers.forEach(wrapper => {
          const status = wrapper.getAttribute('data-status');
          const category = wrapper.getAttribute('data-category');
          if (filter === 'todos') {
            status === 'disponible' ? wrapper.classList.remove('hidden-card') : wrapper.classList.add('hidden-card');
          } else if (filter === 'vendido' || filter === 'rentado') {
            status === filter ? wrapper.classList.remove('hidden-card') : wrapper.classList.add('hidden-card');
          } else {
            (category === filter && status === 'disponible') ? wrapper.classList.remove('hidden-card') : wrapper.classList.add('hidden-card');
          }
        });
      });
    });
    (document.querySelector('[data-filter="todos"]') as HTMLElement)?.click();
  }
  window.addEventListener('DOMContentLoaded', setupFilters);
</script>