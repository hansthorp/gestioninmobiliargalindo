---
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import propiedades from '../data/propiedades.json';
---
<BaseLayout title="Catálogo de Propiedades | Inmobiliaria">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <header class="mb-12 text-center">
      <h1 class="text-5xl font-black text-slate-900 tracking-tight">Encuentra tu próximo hogar</h1>
      <p class="text-slate-500 mt-4 text-lg">Explora nuestras exclusivas propiedades en venta y renta</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {propiedades.map((p) => (
        <PropertyCard property={p} />
      ))}
    </div>
  </section>
</BaseLayout>
