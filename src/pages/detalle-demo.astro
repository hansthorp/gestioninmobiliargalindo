---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BedDouble, Bath, Car, Ruler, MapPin, MessageCircle, ChevronLeft, Landmark } from 'lucide-astro';

// 1. EXTRAEMOS LA BASE (será '/galindo')
const base = import.meta.env.BASE_URL;

const property = {
  titulo: "Propiedad con Zoom y Ficha Completa",
  precio: 4200000,
  moneda: "MXN",
  zona: "Fraccionamiento Las Ánimas",
  ciudad: "Xalapa",
  descripcion: "Este prototipo tiene el zoom corregido y la ficha técnica actualizada con metros de terreno. Pasa el cursor sobre la imagen para ver el aumento real. Haz clic en las miniaturas para cambiar de vista.",
  recamaras: 4,
  banos: 3,
  estacionamientos: 2,
  m2Construccion: 210,
  m2Terreno: 350,
  contacto: { whatsapp: "522281852255" } // Actualizado con tu número
};

const formatCurrency = (value, currency) =>
  new Intl.NumberFormat('es-MX', { style: 'currency', currency, maximumFractionDigits: 0 }).format(value);

const randomImages = Array.from({ length: 6 }, (_, i) => `https://picsum.photos/1200/900?random=${i + 40}`);
---

<BaseLayout title="Detalle Pro | Inmobiliaria">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <a href={base} class="inline-flex items-center gap-2 text-slate-500 hover:text-red-600 transition-colors mb-8 font-bold">
      <ChevronLeft class="h-5 w-5" /> Volver al catálogo
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div class="space-y-4">
        <div class="relative overflow-hidden rounded-3xl shadow-2xl border-4 border-white bg-slate-100 cursor-none" id="zoom-area">
          <img 
            id="main-image" 
            src={randomImages[0]} 
            class="w-full h-[500px] object-cover transition-opacity duration-300" 
            alt="Imagen principal"
          />
          <div 
            id="zoom-lens" 
            class="absolute pointer-events-none rounded-full border-2 border-white shadow-xl opacity-0 transition-opacity duration-200"
            style="width: 180px; height: 180px; background-repeat: no-repeat; display: none; z-index: 10;"
          ></div>
        </div>

        <div class="grid grid-cols-6 gap-2">
          {randomImages.map((img) => (
            <button class="thumb-btn rounded-xl overflow-hidden h-16 border-2 border-transparent hover:border-red-500 transition-all" data-src={img}>
              <img src={img} class="w-full h-full object-cover" />
            </button>
          ))}
        </div>
      </div>

      <div>
        <h1 class="text-4xl font-black text-slate-900 mb-4 tracking-tight uppercase leading-tight">{property.titulo}</h1>
        <p class="flex items-center gap-2 text-slate-500 mb-8 font-medium italic">
          <MapPin class="h-5 w-5 text-red-500" /> {property.zona}, {property.ciudad}
        </p>
        <div class="text-5xl font-black text-red-600 mb-10 tracking-tighter italic">
          {formatCurrency(property.precio, property.moneda)}
        </div>

        <div class="grid grid-cols-5 gap-1 p-4 bg-white border border-slate-100 rounded-3xl mb-10 shadow-sm text-center">
          <div class="flex flex-col items-center border-r border-slate-50">
            <BedDouble class="text-slate-400 mb-1 h-5 w-5" />
            <span class="text-sm font-bold text-slate-900">{property.recamaras}</span>
            <span class="text-[8px] text-slate-400 font-black uppercase tracking-tighter">Hab.</span>
          </div>
          <div class="flex flex-col items-center border-r border-slate-50">
            <Bath class="text-slate-400 mb-1 h-5 w-5" />
            <span class="text-sm font-bold text-slate-900">{property.banos}</span>
            <span class="text-[8px] text-slate-400 font-black uppercase tracking-tighter">Baños</span>
          </div>
          <div class="flex flex-col items-center border-r border-slate-50">
            <Car class="text-slate-400 mb-1 h-5 w-5" />
            <span class="text-sm font-bold text-slate-900">{property.estacionamientos}</span>
            <span class="text-[8px] text-slate-400 font-black uppercase tracking-tighter">Estac.</span>
          </div>
          <div class="flex flex-col items-center border-r border-slate-50">
            <Ruler class="text-slate-400 mb-1 h-5 w-5" />
            <span class="text-sm font-bold text-slate-900">{property.m2Construccion}</span>
            <span class="text-[8px] text-slate-400 font-black uppercase tracking-tighter">Const.</span>
          </div>
          <div class="flex flex-col items-center">
            <Landmark class="text-red-600 mb-1 h-5 w-5" />
            <span class="text-sm font-bold text-red-700">{property.m2Terreno}</span>
            <span class="text-[8px] text-slate-400 font-black uppercase tracking-tighter">Terr.</span>
          </div>
        </div>

        <p class="text-slate-600 leading-relaxed mb-10 border-l-4 border-red-500 pl-4 italic bg-slate-50 py-4 rounded-r-2xl">
          {property.descripcion}
        </p>
        
        <a 
          href={`https://wa.me/${property.contacto.whatsapp}`} 
          target="_blank"
          class="flex items-center justify-center gap-3 bg-green-600 text-white py-5 rounded-2xl font-black text-xl hover:bg-green-700 transition-all shadow-xl shadow-green-100 hover:-translate-y-1"
        >
          <MessageCircle class="h-6 w-6" /> CONTACTAR POR WHATSAPP
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Lógica de Zoom y Galería (Sin cambios, ya son compatibles)
  const zoomArea = document.getElementById('zoom-area');
  const zoomLens = document.getElementById('zoom-lens');
  const mainImage = document.getElementById('main-image') as HTMLImageElement;
  const thumbBtns = document.querySelectorAll('.thumb-btn');

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src');
      if(src && mainImage) {
        mainImage.style.opacity = '0.5';
        setTimeout(() => {
          mainImage.src = src;
          if(zoomLens) zoomLens.style.backgroundImage = `url('${src}')`;
          mainImage.style.opacity = '1';
        }, 150);
      }
    });
  });

  if (zoomArea && zoomLens && mainImage) {
    zoomArea.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = zoomArea.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const lensSize = 180;

      let posX = x - lensSize / 2;
      let posY = y - lensSize / 2;

      if (posX < 0) posX = 0;
      if (posY < 0) posY = 0;
      if (posX > rect.width - lensSize) posX = rect.width - lensSize;
      if (posY > rect.height - lensSize) posY = rect.height - lensSize;

      zoomLens.style.left = `${posX}px`;
      zoomLens.style.top = `${posY}px`;

      const zoomFactor = 2.5; 
      zoomLens.style.backgroundImage = `url('${mainImage.src}')`;
      zoomLens.style.backgroundSize = `${rect.width * zoomFactor}px ${rect.height * zoomFactor}px`;
      zoomLens.style.backgroundPosition = `-${x * zoomFactor - lensSize / 2}px -${y * zoomFactor - lensSize / 2}px`;
    });

    zoomArea.addEventListener('mouseenter', () => {
      zoomLens.style.display = 'block';
      zoomLens.style.opacity = '1';
    });

    zoomArea.addEventListener('mouseleave', () => {
      zoomLens.style.opacity = '0';
      setTimeout(() => { 
        if(zoomLens) zoomLens.style.display = 'none'; 
      }, 200);
    });
  }
</script>