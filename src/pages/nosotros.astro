---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ShieldCheck, Target, Award, Users } from 'lucide-astro';

// EXTRAEMOS LA RUTA BASE DEL CONFIG (será '/galindo')
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Sobre Nosotros | Gestión Inmobiliaria Galindo">
  <section class="relative bg-white rounded-t-[3rem] shadow-xl border border-slate-100 overflow-hidden mb-16">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=2000&auto=format&fit=crop" 
        alt="Asesoría Inmobiliaria Profesional" 
        class="w-full h-full object-cover opacity-10"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-white via-white/80 to-white"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-700 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-[0.2em] mb-6 border border-red-100">
        <Award class="h-4 w-4" /> Trayectoria y Confianza
      </div>
      <h1 class="text-6xl md:text-7xl font-black text-slate-950 tracking-tighter uppercase leading-none">
        Gestión Inmobiliaria <span class="text-red-600">Galindo</span>
      </h1>
      <p class="mt-8 text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium italic">
        "Tu patrimonio en buenas manos. Más de una década uniendo familias con su hogar ideal en Xalapa."
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-10 mb-20 text-center">
      <div class="bg-white p-12 rounded-[2.5rem] border border-slate-100 shadow-lg hover:shadow-2xl transition-all duration-300 group hover:-translate-y-2">
        <div class="h-16 w-16 bg-red-600 rounded-2xl flex items-center justify-center text-white mb-8 mx-auto shadow-lg shadow-red-200">
          <Target class="h-8 w-8" />
        </div>
        <h2 class="text-3xl font-black text-slate-950 mb-6 uppercase tracking-tighter">Nuestra Misión</h2>
        <p class="text-slate-600 leading-relaxed text-lg font-medium italic">
          "Proporcionar soluciones inmobiliarias integrales que garanticen la seguridad jurídica y financiera de nuestros clientes, basándonos en la ética y la transparencia total en cada contrato."
        </p>
      </div>

      <div class="bg-white p-12 rounded-[2.5rem] border border-slate-100 shadow-lg hover:shadow-2xl transition-all duration-300 group hover:-translate-y-2">
        <div class="h-16 w-16 bg-slate-800 rounded-2xl flex items-center justify-center text-white mb-8 mx-auto shadow-lg shadow-slate-300">
          <ShieldCheck class="h-8 w-8" />
        </div>
        <h2 class="text-3xl font-black text-slate-950 mb-6 uppercase tracking-tighter">Nuestra Visión</h2>
        <p class="text-slate-600 leading-relaxed text-lg font-medium">
          Consolidarnos como la empresa líder y más confiable de Veracruz, innovando en la gestión digital de inmuebles y manteniendo siempre el trato humano que nos caracteriza.
        </p>
      </div>
    </div>

    <section class="bg-slate-50 rounded-[3rem] p-16 border border-slate-100 shadow-inner">
      <h3 class="text-center text-4xl font-black mb-16 uppercase tracking-widest text-slate-950">Nuestros Pilares</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
        <div class="bg-white p-10 rounded-3xl shadow-md border border-slate-100">
          <div class="text-red-600 text-6xl font-black mb-4 opacity-70 italic">01</div>
          <h4 class="font-black text-2xl mb-4 uppercase tracking-tight text-slate-900">Honradez</h4>
          <p class="text-slate-600 text-base leading-relaxed italic font-medium">Sin letras chiquitas. Procesos claros y legales de principio a fin.</p>
        </div>
        
        <div class="bg-white p-10 rounded-3xl shadow-md border border-slate-100">
          <div class="text-red-600 text-6xl font-black mb-4 opacity-70 italic">02</div>
          <h4 class="font-black text-2xl mb-4 uppercase tracking-tight text-slate-900">Profesionalismo</h4>
          <p class="text-slate-600 text-base leading-relaxed italic font-medium">Asesoría experta respaldada por años de experiencia en el sector.</p>
        </div>
        
        <div class="bg-white p-10 rounded-3xl shadow-md border border-slate-100">
          <div class="text-red-600 text-6xl font-black mb-4 opacity-70 italic">03</div>
          <h4 class="font-black text-2xl mb-4 uppercase tracking-tight text-slate-900">Calidad</h4>
          <p class="text-slate-600 text-base leading-relaxed italic font-medium">Solo las mejores propiedades y el mejor trato para tu familia.</p>
        </div>
      </div>
    </section>

    <div class="mt-24 text-center bg-white p-16 rounded-[3rem] shadow-xl border border-slate-100 relative overflow-hidden">
      <div class="absolute -top-10 -right-10 h-40 w-40 bg-red-50 rounded-full blur-3xl opacity-60"></div>
      
      <Users class="h-16 w-16 text-red-200 mb-8 mx-auto" stroke-width="1" />
      <h2 class="text-4xl font-black text-slate-950 uppercase tracking-tighter leading-none">
        ¿Listo para gestionar tu propiedad con éxito?
      </h2>
      <p class="text-slate-600 mt-6 mb-12 text-xl italic font-medium max-w-2xl mx-auto">
        Permítenos aplicar nuestra experiencia para ayudarte a vender, rentar o encontrar tu hogar ideal en Veracruz.
      </p>
      
      <a 
        href="https://wa.me/522281852255" 
        target="_blank" 
        class="inline-block bg-red-600 text-white px-12 py-6 rounded-2xl font-black text-xl hover:bg-slate-800 transition-all shadow-2xl shadow-red-200 hover:shadow-slate-300 hover:-translate-y-1"
      >
        CONTACTAR UN ASESOR GALINDO
      </a>
      
      <div class="mt-8">
        <a href={base} class="text-slate-400 font-black uppercase text-xs tracking-widest hover:text-red-600 transition-colors">
          ← Volver al Catálogo
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  :global(body) {
    background-color: #F8FAFC; 
  }
</style>