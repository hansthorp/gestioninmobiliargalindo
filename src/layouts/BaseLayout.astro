---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gestión Inmobiliaria Galindo | Tu patrimonio en buenas manos',
  description = 'Bienes Raíces en Xalapa y Veracruz. Calidad, honradez y profesionalismo.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 selection:bg-galindo/10 selection:text-galindo">
    
    <div class="bg-slate-900 text-white py-2 text-[9px] md:text-[10px] font-bold uppercase tracking-[0.2em]">
      <div class="mx-auto max-w-7xl px-4 flex justify-between items-center">
        <span class="italic">Xalapa • Veracruz • Banderilla</span>
        <div class="flex gap-4">
          <a href="tel:2281852255" class="hover:text-galindo transition-colors italic">📞 228 185 2255</a>
        </div>
      </div>
    </div>

    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:py-4">
        
        <a href="/" class="flex items-center group">
          <img 
            src="/images/logo.jpeg" 
            alt="Logo Galindo" 
            class="h-10 md:h-16 w-auto object-contain transition-transform group-hover:scale-105"
          />
        </a>
        
        <nav class="flex items-center gap-3 md:gap-8 text-[9px] md:text-xs font-black uppercase tracking-widest text-slate-500 italic">
          <a href="/" class="hover:text-galindo transition-colors border-b-2 border-galindo text-slate-900 pb-1">Catálogo</a>
          <a href="/nosotros" class="hover:text-galindo transition-colors pb-1">Nosotros</a>
          
          <a href="https://wa.me/522281852255" target="_blank" class="bg-galindo text-white px-3 py-2 md:px-5 md:py-2.5 rounded-lg md:rounded-xl hover:bg-slate-900 transition-all shadow-lg shadow-red-100/50 not-italic text-[8px] md:text-[10px] uppercase font-black tracking-tighter">
            Vende <span class="hidden md:inline">propiedad</span>
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 md:py-12">
      <slot />
    </main>

    <footer class="bg-slate-900 text-white py-16 mt-20">
      <div class="mx-auto max-w-7xl px-4 grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <div class="flex items-center mb-6">
            <img src="/images/logo.jpeg" class="h-10 w-auto grayscale invert opacity-50" />
          </div>
          <p class="mt-4 text-slate-400 text-sm leading-relaxed italic">
            Ofreciendo servicios de calidad, honradez y profesionalismo en todas las áreas de bienes raíces.
          </p>
        </div>
        
        <div>
          <h4 class="font-bold uppercase text-xs tracking-widest mb-6 text-galindo italic">Contacto</h4>
          <ul class="text-sm text-slate-400 space-y-3 italic">
            <li>📍 Heriberto Jara #24, Col. 10 de Mayo, Xalapa</li>
            <li>📧 asesor_inmobiliario_gc@hotmail.com</li>
            <li>📱 228 185 2255</li>
          </ul>
        </div>
        
        <div>
          <h4 class="font-bold uppercase text-xs tracking-widest mb-6 text-galindo italic">Horario</h4>
          <p class="text-sm text-slate-400 italic font-medium">
            Lunes a Viernes: 9:00 AM - 6:00 PM<br>
            Sábados: 10:00 AM - 2:00 PM
          </p>
        </div>
      </div>
      
      <div class="mx-auto max-w-7xl px-4 mt-16 pt-8 border-t border-slate-800 text-[10px] text-slate-500 text-center uppercase tracking-widest italic">
        © 2026 Gestión Inmobiliaria Galindo - Todos los derechos reservados.
      </div>
    </footer>
  </body>
</html>