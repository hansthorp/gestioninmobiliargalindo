---
import { BedDouble, Bath, Car, Ruler, MapPin, MessageCircle, Landmark } from 'lucide-astro';

interface Props {
  property: any;
}

const { property } = Astro.props;

const formatCurrency = (value, currency) =>
  new Intl.NumberFormat('es-MX', {
    style: 'currency',
    currency,
    maximumFractionDigits: 0
  }).format(value);

const whatsappUrl = `https://wa.me/${property.contacto.whatsapp}?text=${encodeURIComponent(property.contacto.mensajeBase)}`;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
  <a href={`/propiedades/${property.slug}`} class="relative block h-64 overflow-hidden">
    <img src={property.imagenes[0]} alt={property.titulo} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" />
    <div class="absolute left-4 top-4">
      <span class="rounded-lg bg-emerald-600 px-3 py-1 text-[10px] font-black uppercase text-white shadow-lg">{property.operacion}</span>
    </div>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4">
      <div class="text-2xl font-black text-slate-900 leading-tight">{formatCurrency(property.precio, property.moneda)}</div>
      <h3 class="mt-1 line-clamp-1 text-lg font-bold text-slate-800">{property.titulo}</h3>
      <p class="mt-1 flex items-center gap-1 text-sm font-medium text-slate-500 italic">
        <MapPin class="h-3 w-3 text-emerald-500" /> {property.zona}, {property.ciudad}
      </p>
    </div>

    <div class="mb-5 grid grid-cols-5 gap-1 border-y border-slate-100 py-4 text-slate-600 text-center bg-slate-50/50 rounded-xl">
      <div class="flex flex-col items-center border-r border-slate-200"><BedDouble class="h-4 w-4 mb-1" /><span class="text-sm font-bold text-slate-900">{property.recamaras}</span></div>
      <div class="flex flex-col items-center border-r border-slate-200"><Bath class="h-4 w-4 mb-1" /><span class="text-sm font-bold text-slate-900">{property.banos}</span></div>
      <div class="flex flex-col items-center border-r border-slate-200"><Car class="h-4 w-4 mb-1" /><span class="text-sm font-bold text-slate-900">{property.estacionamientos}</span></div>
      <div class="flex flex-col items-center border-r border-slate-200"><Ruler class="h-4 w-4 mb-1" /><span class="text-sm font-bold text-slate-900">{property.m2Construccion}</span></div>
      <div class="flex flex-col items-center"><Landmark class="h-4 w-4 text-emerald-600 mb-1" /><span class="text-sm font-bold text-emerald-600">{property.m2Terreno}</span></div>
    </div>

    <div class="mt-auto flex gap-2">
      <a href={`/propiedades/${property.slug}`} class="flex-1 rounded-xl bg-slate-900 py-3.5 text-center text-sm font-black text-white hover:bg-emerald-700 transition-all shadow-lg shadow-slate-200">
        Ver Detalles
      </a>
      <a href={whatsappUrl} target="_blank" class="rounded-xl border-2 border-green-600 px-4 py-3 text-green-600 hover:bg-green-600 hover:text-white transition-all">
        <MessageCircle class="h-5 w-5" />
      </a>
    </div>
  </div>
</article>
