---
import { BedDouble, Bath, Car, Ruler, MapPin, MessageCircle, Landmark, CheckCircle2, Timer } from 'lucide-astro';

interface Props {
  property: any;
}

const { property } = Astro.props;

// ✅ RUTA ABSOLUTA: Ajustado para usar el slug del JSON plano
const detailUrl = `/propiedades/${property.slug}`;

const estatus = property.estatus?.toLowerCase().trim();
const isVendido = estatus === 'vendido';
const isRentado = estatus === 'rentado';
const isCerrado = isVendido || isRentado;

// ✅ FECHA: Ajustado a 'fecha_publicacion' que es la que viene en tu JSON plano
const fechaPub = new Date(property.fecha_publicacion || Date.now());
const hoy = new Date();
const diferenciaDias = Math.floor((hoy.getTime() - fechaPub.getTime()) / (1000 * 60 * 60 * 24));
const isNuevo = diferenciaDias <= 15 && !isCerrado;

// ✅ MONEDA: Ajustado para que si no existe 'moneda', use 'MXN' por defecto
const formatCurrency = (value, currency = 'MXN') =>
  new Intl.NumberFormat('es-MX', { style: 'currency', currency, maximumFractionDigits: 0 }).format(value || 0);

// ✅ WHATSAPP: Acceso directo (JSON PLANO) para evitar el error de 'undefined'
const whatsappNum = property.whatsapp || "2281852255";
const mensajeBase = `Hola, me interesa la propiedad: ${property.titulo} (ID: ${property.id})`;
const whatsappUrl = `https://wa.me/${whatsappNum}?text=${encodeURIComponent(mensajeBase)}`;
---

<article class={`group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl ${isCerrado ? 'opacity-85' : ''}`}>
  
  <a href={detailUrl} class="relative block h-64 overflow-hidden cursor-pointer">
    <img 
      src={property.imagenes?.[0] || "/images/placeholder-galindo.jpg"} 
      alt={property.titulo} 
      class={`h-full w-full object-cover transition-transform duration-700 group-hover:scale-110 ${isCerrado ? 'grayscale' : ''}`} 
    />
    
    <div class="absolute left-4 top-4 flex flex-col gap-2">
      <span class={`rounded-lg px-3 py-1 text-[10px] font-black uppercase text-white shadow-lg ${isCerrado ? 'bg-slate-500' : 'bg-galindo'}`}>
        En {property.operacion}
      </span>

      {isVendido && (
        <span class="flex items-center gap-1 rounded-lg bg-galindo px-3 py-1 text-[10px] font-black uppercase text-white shadow-lg shadow-red-200">
          <CheckCircle2 class="h-3 w-3" /> VENDIDO
        </span>
      )}

      {isNuevo && (
        <span class="flex items-center gap-1 rounded-lg bg-amber-400 px-3 py-1 text-[10px] font-black uppercase text-slate-900 shadow-lg">
          <Timer class="h-3 w-3" /> ¡NUEVO!
        </span>
      )}
    </div>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4">
      <div class={`text-2xl font-black leading-tight ${isCerrado ? 'text-slate-400 line-through' : 'text-galindo'}`}>
        {formatCurrency(property.precio, property.moneda)}
      </div>
      <h3 class="mt-1 line-clamp-1 text-lg font-bold text-slate-800 italic uppercase tracking-tighter">{property.titulo}</h3>
      <p class="mt-1 flex items-center gap-1 text-sm font-medium text-slate-500 italic">
        <MapPin class="h-3 w-3 text-red-500" /> {property.zona}, {property.ciudad}
      </p>
    </div>

    <div class="mb-5 grid grid-cols-5 gap-1 border-y border-slate-100 py-4 text-slate-600 text-center bg-slate-50/50 rounded-xl">
        <div class="flex flex-col items-center border-r border-slate-200">
          <BedDouble class="h-4 w-4 mb-1" />
          <span class="text-sm font-bold text-slate-900">{property.recamaras || 0}</span>
        </div>
        <div class="flex flex-col items-center border-r border-slate-200">
          <Bath class="h-4 w-4 mb-1" />
          <span class="text-sm font-bold text-slate-900">{property.banos || 0}</span>
        </div>
        <div class="flex flex-col items-center border-r border-slate-200">
          <Car class="h-4 w-4 mb-1" />
          <span class="text-sm font-bold text-slate-900">{property.estacionamientos || 0}</span>
        </div>
        <div class="flex flex-col items-center border-r border-slate-200">
          <Ruler class="h-4 w-4 mb-1 text-red-500" />
          <span class="text-sm font-bold text-slate-900">{property.m2Construccion || 0}</span>
        </div>
        <div class="flex flex-col items-center">
          <Landmark class="h-4 w-4 text-galindo mb-1" />
          <span class="text-sm font-bold text-galindo">{property.m2Terreno || 0}</span>
        </div>
    </div>

    <div class="mt-auto flex gap-2">
      {isCerrado ? (
        <div class="flex-1 text-center py-3.5 text-sm font-black uppercase text-slate-500 bg-slate-100 rounded-xl italic border border-slate-200">
           {property.estatus} 
        </div>
      ) : (
        <>
          <a 
            href={detailUrl} 
            class="flex-1 rounded-xl bg-slate-900 py-3.5 text-center text-sm font-black text-white hover:bg-galindo transition-all shadow-lg active:scale-95 uppercase tracking-widest"
          >
            Ver Detalles
          </a>
          <a 
            href={whatsappUrl} 
            target="_blank" 
            class="rounded-xl border-2 border-[#25D366] px-4 py-3 text-[#25D366] hover:bg-[#25D366] hover:text-white transition-all active:scale-95 shadow-md"
          >
            <MessageCircle class="h-5 w-5" />
          </a>
        </>
      )}
    </div>
  </div>
</article>