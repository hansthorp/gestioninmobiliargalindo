---
import { BedDouble, Bath, Car, Ruler, MapPin, MessageCircle } from 'lucide-astro';

interface Props {
  property: any;
}

const { property } = Astro.props;

const formatCurrency = (value, currency) =>
  new Intl.NumberFormat('es-MX', {
    style: 'currency',
    currency,
    maximumFractionDigits: 0
  }).format(value);

// Enlace genérico para el demo
const demoDetailsUrl = "/detalle-demo/";
const whatsappUrl = `https://wa.me/${property.contacto.whatsapp}?text=${encodeURIComponent(property.contacto.mensajeBase)}`;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
  
  <a href={demoDetailsUrl} class="relative block h-72 overflow-hidden">
    <img
      src={property.imagenes[0]}
      alt={property.titulo}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
      decoding="async"
    />
    
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>

    <div class="absolute left-4 top-4 flex gap-2">
      <span class="rounded-lg bg-emerald-600 text-white px-3 py-1.5 text-[10px] font-black uppercase tracking-widest">{property.operacion}</span>
      <span class="rounded-lg bg-white/95 text-slate-900 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest border border-slate-100">{property.tipo}</span>
    </div>
  </a>

  <div class="flex flex-1 flex-col p-6">
    <div class="mb-4">
      <div class="flex items-baseline gap-1">
        <span class="text-3xl font-black text-slate-900">{formatCurrency(property.precio, property.moneda)}</span>
      </div>
      <h3 class="mt-2 line-clamp-1 text-xl font-bold text-slate-800">{property.titulo}</h3>
      <p class="mt-2 flex items-center gap-1 text-sm font-medium text-slate-500">
        <MapPin class="h-4 w-4 text-emerald-500" /> <span class="truncate">{property.zona}, {property.ciudad}</span>
      </p>
    </div>

    <div class="mt-auto flex gap-3">
      <a href={demoDetailsUrl} class="flex-1 rounded-xl bg-slate-900 px-4 py-3.5 text-center text-sm font-bold text-white hover:bg-emerald-700 transition-colors">
        Ver Detalles (Demo)
      </a>
      <a href={whatsappUrl} target="_blank" class="flex items-center justify-center gap-2 rounded-xl border border-green-600 px-5 text-green-600 hover:bg-green-600 hover:text-white transition-colors">
        <MessageCircle class="h-5 w-5" />
      </a>
    </div>
  </div>
</article>
